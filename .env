# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection
MONGODB_URI=mongodb://<username>:<password>@ac-cebkaox-shard-00-00.ikggs6d.mongodb.net:27017,ac-cebkaox-shard-00-01.ikggs6d.mongodb.net:27017,ac-cebkaox-shard-00-02.ikggs6d.mongodb.net:27017/?ssl=true&replicaSet=atlas-3cdj4j-shard-0&authSource=admin&appName=Cluster0
